#include <stdio.h>

int main(){
    int aniverdia, anivermes, aniverano, atualdia, atualmes, atualano;
    scanf ("%d/%d/%d %d/%d/%d", &aniverdia, &anivermes, &aniverano, &atualdia, &atualmes, &atualano);

    //--------------------------------------------------------//
    // Amor
    int SomaAmor = aniverdia + anivermes + aniverano + atualdia + atualmes + atualano;
    int Amor = (SomaAmor * 7) % 101;

    if (Amor > 80){printf("Amor: %d%% Um dia deslumbrantemente lindo para amar. Ps: Cuidado com a intensidade.\n", Amor);}
    else if (Amor >= 70){printf("Amor: %d%% Saia com o coracao aberto, mas lembre, nem toda troca de olhar em onibus e sinal de romance.\n", Amor);}
    else if (Amor >= 41){printf("Amor: %d%% Se o papo e as ideias baterem, esta liberado pensar em algo.\n", Amor);}
    else if (Amor >= 20){printf("Amor: %d%% Melhor manter o coracao <3 longe de perigo.\n", Amor);}
    else{printf("Amor: %d%% Pessimo dia para se apaixonar.\n", Amor);}

    //--------------------------------------------------------//
    // Sorte
    int DiferencaAnos = atualano - aniverano;
    int Sorte = (((aniverdia + atualdia + anivermes + atualmes) * 9) + DiferencaAnos) % 101;

    if (Sorte > 90){printf("Sorte: %d%% Nao tenha medo de virar cartas hoje. Sem tigrinho nem jogos de azar, por favor!\n", Sorte);}
    else if (Sorte >= 80){printf("Sorte: %d%% Hoje vale a pena arriscar. Sem tigrinho nem jogos de azar, por favor!\n", Sorte);}
    else if (Sorte >= 51){printf("Sorte: %d%% Por sua conta em risco. Sem tigrinho nem jogos de azar, por favor!\n", Sorte);}
    else if (Sorte >= 30){printf("Sorte: %d%% Melhor nao arriscar. Sem tigrinho nem jogos de azar, por favor!\n", Sorte);}
    else{printf("Sorte: %d%% Nem jogue moedas pra cima hoje. Sem tigrinho nem jogos de azar, por favor!\n", Sorte);}

    //--------------------------------------------------------//
    // Trabalho
    int Trabalho = ((aniverano + atualano) - ((atualdia + aniverdia + anivermes + atualmes) * 8)) % 101;
    if (Trabalho < 0){Trabalho += 101;}

    if (Trabalho > 85){printf("Trabalho: %d%% Use do maximo de networking possível hoje, dia bom para negocios.\n", Trabalho);}
    else if (Trabalho >= 70){printf("Trabalho: %d%% Boas vibracoes hoje, chances podem estar ao seu redor.\n", Trabalho);}
    else if (Trabalho >= 51){printf("Trabalho: %d%% Um dia proveitoso com certeza, leve sua simpatia consigo.\n", Trabalho);}
    else if (Trabalho >= 40){printf("Trabalho: %d%% Segura a emocao, nao xinga ninguem, nao esquece de beber agua.\n", Trabalho);}
    else{printf("Trabalho: %d%% Hoje nao sera um dia tao proveitoso, keep calm e faca o basico.\n", Trabalho);}

    //--------------------------------------------------------//
    // Cor
    int Cor = ((aniverdia * aniverdia) + (atualdia * atualdia) + (anivermes * anivermes) + (atualmes * atualmes) + (aniverano * aniverano) + (atualano * atualano)) % 11;

    switch(Cor){
        case 0: printf("Cor: Cinza.\n"); break;
        case 1: printf("Cor: Vermelho.\n"); break;
        case 2: printf("Cor: Laranja.\n"); break;
        case 3: printf("Cor: Amarelo.\n"); break;
        case 4: printf("Cor: Verde.\n"); break;
        case 5: printf("Cor: Azul.\n"); break;
        case 6: printf("Cor: Roxo.\n"); break;
        case 7: printf("Cor: Marrom.\n"); break;
        case 8: printf("Cor: Rosa.\n"); break;
        case 9: printf("Cor: Preto.\n"); break;
        case 10: printf("Cor: Branco.\n");
    }
    return 0;
}
