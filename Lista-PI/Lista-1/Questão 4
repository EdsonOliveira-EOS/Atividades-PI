            else if (quadrantebloqueado == 3){printf("%d passos em x e %d passos em y\n", passosx, passosy);}
            else{printf("caminhada invalida\n");}
            break;
        case 3:
            if (quadrantebloqueado == 2){printf("%d passos em x e %d passos em y\n", passosx, passosy);}
            else if (quadrantebloqueado == 4){printf("%d passos em y e %d passos em x\n", passosy, passosx);}
            else{printf("caminhada invalida\n");}
